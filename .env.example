GROQ_API_KEY="GROQ_API_KEY"
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_TEMPERATURE="0.2"

# Optional: override the rule table path
# AEA_RULE_TABLE_PATH="/workspace/data/etkilesimler.csv"

# RAG / Vector DB (Chroma) defaults
# PDFs klasörü
# AEA_PDF_INPUT_DIR="pdfs"
# Chroma persist alanı
# CHROMA_PERSIST_DIR="vector_db/chroma"
# Chroma collection adı
# CHROMA_COLLECTION="aea_kub_kt"
# Embedding modeli
# AEA_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
# Chunking
# AEA_CHUNK_SIZE="900"
# AEA_CHUNK_OVERLAP="150"

