# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_TEMPERATURE="0.2"

# ── Admin Paneli ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD="your_admin_password_here"

# ── RAG / Vector DB (Chroma) ──────────────────────────────────────────────────
AEA_EMBEDDING_MODEL="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
# Optional overrides:
# AEA_RULE_TABLE_PATH="/workspace/data/etkilesimler.csv"
# AEA_PDF_INPUT_DIR="pdfs"
# CHROMA_PERSIST_DIR="vector_db/chroma"
# CHROMA_COLLECTION="aea_kub_kt"
# AEA_CHUNK_SIZE="900"
# AEA_CHUNK_OVERLAP="150"
# AEA_RAG_K="4"

# ── Web Search Fallback ───────────────────────────────────────────────────────
# AEA_WEB_SEARCH="0"   # "1" ile aktifleştir

# ── LangFuse (Observability) ─────────────────────────────────────────────────
# https://cloud.langfuse.com adresinden ücretsiz key alın
LANGFUSE_SECRET_KEY="YOUR_LANGFUSE_SECRET_KEY"
LANGFUSE_PUBLIC_KEY="YOUR_LANGFUSE_PUBLIC_KEY"
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# ── LangSmith (Observability) ─────────────────────────────────────────────────
# https://smith.langchain.com adresinden ücretsiz API key alın
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="AEA-Pharmacist-Assistant"
LANGCHAIN_API_KEY="YOUR_LANGSMITH_API_KEY"
